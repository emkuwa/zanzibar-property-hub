# ZanziInvest – Frontend env (optional)
# Copy to .env and set for local dev or override production API.

# Backend API base URL (no trailing slash). Omit in production on Vercel so the app uses same-origin HTTPS (/api/*).
# Dev: http://127.0.0.1:5051
# Prod (optional): https://api.zanziinvest.com — must be https:// if the site is served over HTTPS.
# VITE_API_BASE_URL=http://127.0.0.1:5051

# Dashboard iframe URL (optional). Default: dev http://localhost:5052, prod https://dashboard.zanziinvest.com
# VITE_DASHBOARD_URL=https://dashboard.zanziinvest.com
